{
    "name": "quickpoll/quickpoll",
    "description": "A tiny, dependency-free PHP app for creating and sharing polls with real-time results.",
    "type": "project",
    "keywords": ["poll", "survey", "voting", "php", "sqlite"],
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "serve": "php -S localhost:8000 -t public",
        "hash-password": "php bin/hash-password.php"
    },
    "config": {
        "sort-packages": true
    }
}
